{
  "name": "api",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/api/src",
  "targets": {
    "build": {
      "dependsOn": ["prisma-generate"],
      "command": "npx tsc -b",
      "options": {
        "cwd": "apps/api"
      }
    },
    "dev": {
      "command": "npx nodemon",
      "options": {
        "cwd": "apps/api"
      }
    },
    "start": {
      "command": "node -r dotenv/config dist/index.js",
      "options": {
        "cwd": "apps/api"
      }
    },
    "prisma-generate": {
      "command": "npx prisma generate",
      "options": {
        "cwd": "apps/api"
      }
    },
    "lint": {
      "command": "eslint \"src/**\"",
      "options": {
        "cwd": "apps/api"
      }
    }
  }
}
